{
  "name": "hopper-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server for Hopper with indexed state and transaction-safe annotations.",
  "bin": {
    "hopper-mcp": "./bin/hopper-mcp",
    "hopper-mcp-node": "./src/mcp-server.js"
  },
  "scripts": {
    "start": "npm run start:rust",
    "start:rust": "cargo run -p hopper-mcpd --",
    "doctor": "cargo run -p hopper-mcpd -- doctor",
    "doctor:json": "cargo run -p hopper-mcpd -- doctor --json",
    "doctor:plugin-live": "cargo run -p hopper-mcpd -- doctor --json --require-plugin-identity",
    "doctor:distribution": "cargo run -p hopper-mcpd -- doctor --json --require-distribution-identity --require-clean-git-tree",
    "doctor:public-release": "cargo run -p hopper-mcpd -- doctor --json --require-distribution-identity --require-notary-credentials --require-clean-git-tree",
    "package:release": "node scripts/package-release.mjs",
    "package:release:ad-hoc": "node scripts/package-release.mjs --ad-hoc",
    "package:release:dry-run": "node scripts/package-release.mjs --dry-run",
    "package:release:check": "node scripts/package-release.mjs --check",
    "package:verify": "node scripts/package-release.mjs --verify",
    "package:smoke": "node scripts/package-release.mjs --smoke",
    "package:notarize": "node scripts/package-release.mjs --notarize",
    "test:live:corpus": "node scripts/live-corpus.mjs",
    "test:live:corpus:dry-run": "node scripts/live-corpus.mjs --dry-run",
    "test:live:corpus:large-apps": "HOPPER_MCP_CLEANUP_TIMEOUT_MS=60000 node scripts/live-corpus.mjs --manifest corpus/live-large-apps.json",
    "fetch:hopper-sdk": "node scripts/fetch-hopper-sdk.mjs",
    "build:agent": "make -C agents/hopper-agent",
    "build:hopper-plugin": "make -C agents/hopper-tool-plugin",
    "hopper-plugin:service-name": "node scripts/hopper-plugin-runtime.mjs service-name",
    "hopper-plugin:identities": "node scripts/hopper-plugin-runtime.mjs identities",
    "hopper-plugin:install": "node scripts/hopper-plugin-runtime.mjs install",
    "hopper-plugin:probe": "node scripts/hopper-plugin-runtime.mjs probe",
    "cleanup:hopper-state": "node scripts/cleanup-hopper-state.mjs",
    "test:agent": "node --test test/hopper-agent.mjs",
    "build:rust": "cargo build --workspace",
    "check:rust": "cargo check --workspace",
    "fmt:rust": "cargo fmt --check",
    "clippy:rust": "cargo clippy --workspace -- -D warnings",
    "test:rust": "cargo test --workspace",
    "check": "node --check src/*.js && node --check test/*.mjs && node --check test/fixtures/*.mjs",
    "test": "npm run check && node --test test/protocol.mjs test/smoke.mjs test/store.mjs test/lifecycle.mjs test/snapshot.mjs test/transactions.mjs test/research.mjs test/hopper-live-options.mjs test/live-bridge-cli.mjs test/bin-wrapper.mjs test/hopper-agent.mjs test/hopper-plugin-runtime.mjs test/private-backend-runtime.mjs test/private-backend-runtime-launch.mjs test/cleanup-hopper-state.mjs test/package-release.mjs test/release-check.mjs test/live-check.mjs test/plugin-live-check.mjs test/distribution-check.mjs test/public-release-check.mjs test/private-backend-check.mjs test/internal-production-check.mjs test/internal-soak-check.mjs test/public-production-check.mjs test/live-corpus.mjs test/release-scripts.mjs",
    "test:live": "HOPPER_MCP_LIVE=1 node --test test/live.mjs && HOPPER_MCP_LIVE=1 cargo test -p hopper-mcpd --test live_bridge_contract daemon_default_live_bridge_ingests_echo_when_enabled",
    "release:check": "node scripts/release-check.mjs",
    "release:check:live": "node scripts/live-check.mjs",
    "release:check:plugin-live": "node scripts/plugin-live-check.mjs",
    "release:check:distribution": "node scripts/distribution-check.mjs",
    "release:check:private-backend": "node scripts/private-backend-check.mjs",
    "release:check:public-release": "node scripts/public-release-check.mjs",
    "release:check:internal": "node scripts/internal-production-check.mjs",
    "release:check:internal-soak": "node scripts/internal-soak-check.mjs",
    "release:check:public": "node scripts/public-production-check.mjs",
    "test:all": "npm test && npm run test:rust && npm run test:live"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  }
}
